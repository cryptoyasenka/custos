# Custos Nox dashboard environment.
# Copy to `.env.local` for development; on Vercel/Railway set as project env.

# Optional: URL of a running Custos Nox daemon HTTP endpoint. The dashboard
# polls <URL>/events every 5 seconds and renders the live mainnet feed.
# When unset (or unreachable), the live section falls back to the devnet
# attack-simulation sample.
# NEXT_PUBLIC_CUSTOS_DAEMON_URL=https://custos-daemon.up.railway.app
